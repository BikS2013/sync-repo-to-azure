# ---- Application Environment ----

# Node.js environment: "development" | "production" | "test"
# Controls logging detail, stack traces, and development-only features in API mode
NODE_ENV=

# ---- Azure Storage Configuration ----

# Azure Storage Account URL (e.g., https://myaccount.blob.core.windows.net)
AZURE_STORAGE_ACCOUNT_URL=

# Default container name
AZURE_STORAGE_CONTAINER_NAME=

# Authentication method: "connection-string" | "sas-token" | "azure-ad"
AZURE_FS_AUTH_METHOD=

# Connection string (required when AZURE_FS_AUTH_METHOD=connection-string)
# Find in: Azure Portal > Storage Account > Access Keys
AZURE_STORAGE_CONNECTION_STRING=

# SAS token (required when AZURE_FS_AUTH_METHOD=sas-token)
# Generate in: Azure Portal > Storage Account > Shared Access Signature
AZURE_STORAGE_SAS_TOKEN=

# SAS token expiration date in ISO 8601 format (required when AZURE_FS_AUTH_METHOD=sas-token)
# Must match the expiry date set when generating the SAS token
# Example: 2026-12-31T00:00:00Z
AZURE_STORAGE_SAS_TOKEN_EXPIRY=

# Logging level: "debug" | "info" | "warn" | "error"
AZURE_FS_LOG_LEVEL=

# Whether to log Azure SDK requests (true/false)
AZURE_FS_LOG_REQUESTS=

# Retry strategy: "none" | "exponential" | "fixed"
AZURE_FS_RETRY_STRATEGY=

# Maximum number of retries
AZURE_FS_RETRY_MAX_RETRIES=

# Initial delay in milliseconds for retry
AZURE_FS_RETRY_INITIAL_DELAY_MS=

# Maximum delay in milliseconds for retry (exponential backoff cap)
AZURE_FS_RETRY_MAX_DELAY_MS=

# ---- GitHub Repository Replication ----

# GitHub Personal Access Token (required for private repos)
# Generate at: https://github.com/settings/tokens
# Required scopes: repo (for private repos)
# GITHUB_TOKEN=

# GitHub token expiry in ISO 8601 format (optional, warns 7 days before expiry)
# GITHUB_TOKEN_EXPIRY=

# ---- Azure DevOps Repository Replication ----

# Azure DevOps auth method: "pat" | "azure-ad"
# AZURE_DEVOPS_AUTH_METHOD=

# Azure DevOps organization URL (e.g., https://dev.azure.com/myorg)
# AZURE_DEVOPS_ORG_URL=

# Azure DevOps Personal Access Token (required when AZURE_DEVOPS_AUTH_METHOD=pat)
# AZURE_DEVOPS_PAT=

# Azure DevOps PAT expiry in ISO 8601 format (optional, warns 7 days before expiry)
# AZURE_DEVOPS_PAT_EXPIRY=

# ---- Port Conflict Handling ----

# Auto-select available port if configured port is in use (true/false)
# When true, if AZURE_FS_API_PORT is unavailable, the server finds the next available port
# When false, the server fails to start if the port is in use
AUTO_SELECT_PORT=

# ---- REST API Configuration ----

# Port the API server listens on (e.g., 3000, 8080)
AZURE_FS_API_PORT=

# Host/IP the API server binds to (e.g., 0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
AZURE_FS_API_HOST=

# Comma-separated list of allowed CORS origins (e.g., "http://localhost:3000,https://myapp.com" or "*" for all)
AZURE_FS_API_CORS_ORIGINS=

# Enable Swagger UI documentation at /api/docs (true/false)
AZURE_FS_API_SWAGGER_ENABLED=

# Optional: Comma-separated additional Swagger server URLs for testing in different environments
# AZURE_FS_API_SWAGGER_ADDITIONAL_SERVERS=

# Optional: Enable Swagger server variables (true/false) for environment switching
# AZURE_FS_API_SWAGGER_SERVER_VARIABLES=

# Request timeout in milliseconds (requests exceeding this are aborted)
AZURE_FS_API_REQUEST_TIMEOUT_MS=

# ---- Azure Virtual Environment (Remote Config Sync) ----

# Azure Blob Storage URL for remote config sync
# Format: https://<account>.blob.core.windows.net/<container>/<prefix>
# AZURE_VENV=

# SAS token for azure-venv (Read + List permissions, no leading "?")
# AZURE_VENV_SAS_TOKEN=

# SAS token expiry for azure-venv in ISO 8601 format (optional)
# AZURE_VENV_SAS_EXPIRY=

# ---- Container & Cloud Environment (Optional - Auto-detected) ----

# Override public URL for any container runtime
# If not set, auto-detected from WEBSITE_HOSTNAME (Azure App Service), K8S_SERVICE_* (Kubernetes), or DOCKER_HOST_URL
# PUBLIC_URL=

# Docker host URL when running in a Docker container
# Example: http://docker-host:3000
# DOCKER_HOST_URL=

# Auto-set by Azure App Service (DO NOT SET MANUALLY)
# WEBSITE_HOSTNAME=

# Auto-set by Azure App Service (DO NOT SET MANUALLY)
# WEBSITE_SITE_NAME=

# Auto-set by Kubernetes (DO NOT SET MANUALLY)
# K8S_SERVICE_HOST=

# Auto-set by Kubernetes (DO NOT SET MANUALLY)
# K8S_SERVICE_PORT=

# Force HTTPS in Kubernetes environments (true/false) when K8S_SERVICE_* vars are used
# AZURE_FS_API_USE_HTTPS=

# ---- Sync Pair Configuration ----

# Path to sync pair configuration file (JSON or YAML)
# Defines repo-to-Azure-Storage mapping pairs for batch replication
# Can be overridden via CLI: --sync-config <path>
# AZURE_FS_SYNC_CONFIG_PATH=
